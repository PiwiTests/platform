{
  "name": "@piwitests/dashboard",
  "private": true,
  "type": "module",
  "scripts": {
    "app:generate": "nuxt generate",
    "app:generate:demo": "cross-env PIWI_DEMO_MODE=true nuxt generate",
    "app:seed:demo": "node scripts/generate-demo-seed.mjs",
    "app:build": "nuxt build",
    "app:dev": "nuxt dev",
    "app:preview": "nuxt preview",
    "app:lint": "oxlint --config oxlint.config.ts .",
    "app:lint:fix": "oxlint --config oxlint.config.ts . --fix",
    "app:format": "oxfmt --config oxfmt.config.ts --write \".\"",
    "app:format:check": "oxfmt --config oxfmt.config.ts --check \".\"",
    "app:typecheck": "nuxt typecheck",
    "app:gen:spec": "node scripts/generate-openapi-spec.mjs",
    "test": "vitest run && playwright test",
    "app:test": "playwright test",
    "app:test:unit": "vitest run",
    "app:test:ui": "playwright test --ui",
    "app:test:report": "playwright show-report",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:generate:pg": "drizzle-kit generate --config=drizzle.config.pg.ts",
    "db:migrate:pg": "drizzle-kit migrate --config=drizzle.config.pg.ts",
    "db:push:pg": "drizzle-kit push --config=drizzle.config.pg.ts",
    "db:studio:pg": "drizzle-kit studio --config=drizzle.config.pg.ts",
    "app:check:demo": "node scripts/check-demo-routes.mjs",
    "postinstall": "nuxt prepare",
    "app:knip": "knip",
    "app:knip:fix": "knip --fix"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@aws-sdk/client-s3": "^3.721.0",
    "@emnapi/core": "1.11.1",
    "@emnapi/runtime": "1.11.1",
    "@iconify-json/lucide": "^1.2.75",
    "@libsql/client": "^0.17.2",
    "@nuxt/hints": "^1.0.0-alpha.5",
    "@nuxt/test-utils": "^4.0.2",
    "@nuxt/ui": "^4.2.1",
    "@unovis/ts": "^1.6.2",
    "@unovis/vue": "^1.6.2",
    "@vite-pwa/nuxt": "^1.1.1",
    "@vueuse/nuxt": "^14.1.0",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.0",
    "highlight.js": "^11.11.1",
    "nodemailer": "^8.0.11",
    "nuxt": "^4.2.1",
    "postgres": "^3.4.9",
    "sharp": "^0.35.2",
    "sql.js": "^1.14.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "@types/nodemailer": "^8.0.1",
    "@types/sql.js": "^1.4.11",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.8",
    "form-data": "^4.0.0",
    "knip": "^6.20.0",
    "monocart-reporter": "^2.10.1",
    "vue-tsc": "^3.1.5"
  },
  "optionalDependencies": {
    "@libsql/linux-x64-musl": "^0.5.29"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
