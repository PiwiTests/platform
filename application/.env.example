# Public URL, used for OG Image when running nuxt generate
PIWI_SITE_URL=

# Secret key for encrypting sensitive values stored in the database (AI API keys, SCM tokens).
# Generate with: openssl rand -hex 32
# Recommended even without authentication enabled.
PIWI_SECRET_KEY=

# Authentication
# Set to 'true' to enable authentication
PIWI_AUTH_ENABLED=false
# Secret key for encrypting session cookies (required when PIWI_AUTH_ENABLED=true).
# Generate with: openssl rand -hex 32
PIWI_AUTH_SECRET=

# OAuth Authentication (optional, only configure providers you want to use)
# Google OAuth: https://console.developers.google.com/apis/credentials
PIWI_OAUTH_GOOGLE_CLIENT_ID=
PIWI_OAUTH_GOOGLE_CLIENT_SECRET=
# GitHub OAuth: https://github.com/settings/developers
PIWI_OAUTH_GITHUB_CLIENT_ID=
PIWI_OAUTH_GITHUB_CLIENT_SECRET=

# Database Configuration
# By default the dashboard uses a local SQLite database at .data/piwi.db
# To use PostgreSQL instead, set PIWI_DATABASE_URL to a valid connection string:
# PIWI_DATABASE_URL=postgresql://user:password@localhost:5432/piwi_dashboard
PIWI_DATABASE_URL=

# SQLite Settings (when PIWI_DATABASE_URL is not set)
# Path where the SQLite database file will be stored
PIWI_DATABASE_PATH=.data/piwi.db

# Storage Configuration
# Storage type: 'local' (default) or 's3'
PIWI_STORAGE_TYPE=local

# Local Storage Settings (when PIWI_STORAGE_TYPE=local)
# Path where files will be stored locally
PIWI_STORAGE_PATH=.data/storage

# S3 Storage Settings (when PIWI_STORAGE_TYPE=s3)
# AWS S3 bucket name
PIWI_S3_BUCKET=
# AWS region (e.g., us-east-1, eu-west-1)
PIWI_S3_REGION=
# AWS access key ID
PIWI_S3_ACCESS_KEY_ID=
# AWS secret access key
PIWI_S3_SECRET_ACCESS_KEY=
# Optional: Custom S3 endpoint (for S3-compatible services like MinIO, DigitalOcean Spaces, etc.)
PIWI_S3_ENDPOINT=

# AI Diagnosis Configuration (optional)
# Provider: 'anthropic' or 'openai' (OpenAI-compatible, e.g., ollama, vLLM, OpenRouter)
PIWI_AI_PROVIDER=
# API key for the provider (not required for local OpenAI-compatible servers)
PIWI_AI_API_KEY=
# Model to use (default: claude-opus-4-8 for anthropic; required for openai)
PIWI_AI_MODEL=
# Base URL (required for openai provider; optional proxy override for anthropic)
PIWI_AI_BASE_URL=
# Set to 'true' to automatically diagnose new failure clusters when a run finishes (max 3 per run)
PIWI_AI_AUTO_DIAGNOSE=false
# Optional research model (two-stage diagnosis) — a cheaper/faster pre-analysis pass.
# Provider/base URL/API key default to the main ones when omitted.
PIWI_AI_RESEARCH_MODEL=
PIWI_AI_RESEARCH_PROVIDER=
PIWI_AI_RESEARCH_BASE_URL=
PIWI_AI_RESEARCH_API_KEY=
# Optional embedding model (semantic failure clustering). Anthropic has no embeddings API,
# so use an OpenAI-compatible endpoint (OpenAI, Voyage, or a local server like ollama).
PIWI_AI_EMBEDDING_PROVIDER=
PIWI_AI_EMBEDDING_MODEL=
PIWI_AI_EMBEDDING_BASE_URL=
PIWI_AI_EMBEDDING_API_KEY=

# AI Diagnosis Context Limits (optional)
# Cap how much evidence is packed into each diagnosis (and therefore token cost).
# Defaults shown below; these are also editable in Settings → AI. When set, an
# env var takes precedence over the stored setting and the field becomes read-only in the UI.
# PIWI_AI_MAX_SAMPLE_ERROR_CHARS=3000     # characters of raw error text per error block
# PIWI_AI_MAX_SCM_PATCH_BUDGET=4000       # total characters of diff patches across files
# PIWI_AI_MAX_AFFECTED_TESTS=15           # affected tests listed
# PIWI_AI_MAX_STEPS=30                     # recent test steps included
# PIWI_AI_MAX_CONSOLE_ENTRIES=15          # console error/warning entries
# PIWI_AI_MAX_CONSOLE_ENTRY_CHARS=400     # characters per console entry
# PIWI_AI_MAX_NETWORK_REQUESTS=15         # failed network requests included
# PIWI_AI_MAX_ARIA_SNAPSHOT_CHARS=4000    # characters of the page ARIA snapshot
# PIWI_AI_MAX_TEST_SOURCE_CHARS=3000      # characters of the test source snippet
