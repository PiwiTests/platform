# Public URL, used for OG Image when running nuxt generate
NUXT_PUBLIC_SITE_URL=

# Authentication
# Set to 'true' to enable authentication
NUXT_AUTH_ENABLED=false
# Secret key for encrypting sessions (generate a random string, e.g., using openssl rand -hex 32)
NUXT_AUTH_SECRET=

# Storage Configuration
# Storage type: 'local' (default) or 's3'
STORAGE_TYPE=local

# Local Storage Settings (when STORAGE_TYPE=local)
# Path where files will be stored locally
STORAGE_PATH=.data/storage

# S3 Storage Settings (when STORAGE_TYPE=s3)
# AWS S3 bucket name
S3_BUCKET=
# AWS region (e.g., us-east-1, eu-west-1)
S3_REGION=
# AWS access key ID
S3_ACCESS_KEY_ID=
# AWS secret access key
S3_SECRET_ACCESS_KEY=
# Optional: Custom S3 endpoint (for S3-compatible services like MinIO, DigitalOcean Spaces, etc.)
S3_ENDPOINT=
